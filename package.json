{
  "name": "marktexset",
  "version": "0.1.0",
  "description": "Markdown publishing for mathematical documents",
  "type": "module",
  "bin": {
    "marktexset": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "check": "npm run build && npm test"
  },
  "dependencies": {
    "markdown-it": "^14.1.0",
    "markdown-it-footnote": "^4.0.0",
    "mathjax-full": "^3.2.2",
    "ws": "^8.21.1",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
